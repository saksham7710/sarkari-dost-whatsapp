# ============================================
# SARKARI DOST WHATSAPP BOT - ENVIRONMENT
# ============================================
# Fill in these values and you're ready to deploy

# --- Meta WhatsApp Cloud API ---
# Get these from: developers.facebook.com -> Your App -> WhatsApp -> API Setup
WHATSAPP_TOKEN=your_permanent_access_token_here
WHATSAPP_PHONE_ID=your_phone_number_id_here
META_VERIFY_TOKEN=create_any_random_string_here

# --- Twilio (Optional - for quick testing) ---
# Get these from: twilio.com/console
TWILIO_SID=your_twilio_account_sid
TWILIO_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- Server ---
PORT=3000
